PORT=5000
NODE_ENV=production
STORAGE_PATH=/opt/VpnHoodServer/storage/access
VH_SERVER_CMD=sudo /opt/VpnHoodServer/vhserver
UPSTREAM_REPO=https://github.com/yourusername/your-repo-name.git
WEBHOOK_SECRET=your_super_secret_string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/vpnhood?retryWrites=true&w=majority
TOKEN_SECRET=generate_with_openssl_rand_hex_64
REFRESH_TOKEN_SECRET=generate_with_openssl_rand_hex_64
CORS_ORIGIN=https://yourdomain.com
# 100 requests per 15 minutes.
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000